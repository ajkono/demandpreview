          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "DECLARE @run_id BIGINT = CAST('${run_id:raw}' AS BIGINT);\r\nDECLARE @prev_run_id BIGINT = CAST('${prev_run_id:raw}' AS BIGINT);\r\n\r\nWITH current_run AS\r\n(\r\n    SELECT\r\n        orderSeq,\r\n        category,\r\n        date,\r\n        MAX(value) AS value\r\n    FROM DemandPreview.dbo.demand_preview\r\n    WHERE run_id = @run_id\r\n      AND process = '1MN1'\r\n    GROUP BY orderSeq, category, date\r\n),\r\n\r\nprevious_run AS\r\n(\r\n    SELECT\r\n        orderSeq,\r\n        category,\r\n        date,\r\n        MAX(value) AS value\r\n    FROM DemandPreview.dbo.demand_preview\r\n    WHERE run_id = @prev_run_id\r\n      AND process = '1MN1'\r\n    GROUP BY orderSeq, category, date\r\n),\r\n\r\ncurrent_seq AS\r\n(\r\n    SELECT\r\n        orderSeq,\r\n        MAX(category) AS category\r\n    FROM current_run\r\n    GROUP BY orderSeq\r\n),\r\n\r\nprevious_seq AS\r\n(\r\n    SELECT\r\n        orderSeq,\r\n        MAX(category) AS category\r\n    FROM previous_run\r\n    GROUP BY orderSeq\r\n),\r\n\r\nseq_status AS\r\n(\r\n    SELECT\r\n        cs.orderSeq,\r\n        cs.category,\r\n        CASE\r\n            WHEN ps.category <> cs.category THEN '[CHANGED] '\r\n            ELSE ''\r\n        END AS marker\r\n    FROM current_seq cs\r\n    LEFT JOIN previous_seq ps\r\n        ON cs.orderSeq = ps.orderSeq\r\n)\r\n\r\nSELECT\r\n    CONCAT(\r\n        s.marker,\r\n        s.orderSeq,\r\n        ' ',\r\n        s.category\r\n    ) AS orderSeq,\r\n\r\n    FORMAT(c.date,'yyyy-MM-dd') AS date,\r\n\r\n    CONCAT(\r\n        c.value,\r\n        CASE\r\n            WHEN p.value IS NULL THEN ''\r\n            WHEN c.value = p.value THEN ''\r\n            WHEN c.value > p.value THEN CONCAT(' (+', c.value - p.value, ')')\r\n            WHEN c.value < p.value THEN CONCAT(' (-', p.value - c.value, ')')\r\n        END\r\n    ) AS value_with_delta\r\n\r\nFROM current_run c\r\n\r\nJOIN seq_status s\r\n    ON c.orderSeq = s.orderSeq\r\n\r\nLEFT JOIN previous_run p\r\n    ON c.orderSeq = p.orderSeq\r\n    AND c.category = p.category\r\n    AND c.date = p.date\r\n\r\nORDER BY c.orderSeq, c.date;",
          "refId": "A",
